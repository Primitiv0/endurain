{
  "name": "endurain",
  "version": "0.19.0-beta3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:oxlint lint:eslint",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "lint:check": "run-s lint:check:oxlint lint:check:eslint",
    "lint:check:oxlint": "oxlint .",
    "lint:check:eslint": "eslint . --cache",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check --experimental-cli src/",
    "gen:api": "npx -y openapi-typescript@7.13.0 \"${ENDURAIN_OPENAPI_SOURCE:-openapi.json}\" --output src/types/api.generated.ts",
    "check": "run-s type-check lint:check format:check test"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/vue": "^1.21.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/vue-query": "^5.101.0",
    "chart.js": "^4.5.1",
    "chartjs-plugin-zoom": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "leaflet": "^1.9.4",
    "marked": "^18.0.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.71.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxlint": "^1.71.0",
    "prettier": "3.8.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
