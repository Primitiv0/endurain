[importlinter]
# Run from backend/ with: PYTHONPATH=app uv run lint-imports
root_packages =
    auth
    users
    activities
    core
    followers
    garmin
    gears
    health
    notifications
    password_reset_tokens
    profile
    server_settings
    sign_up_tokens
    strava
    websocket

[importlinter:contract:auth-boundary]
name = Auth boundary: non-auth must not import auth internals directly
type = forbidden
allow_indirect_imports = True
source_modules =
    users
    activities
    core
    followers
    garmin
    gears
    health
    notifications
    password_reset_tokens
    profile
    server_settings
    sign_up_tokens
    strava
    websocket
forbidden_modules =
    auth.security
    auth.password_hasher
    auth.token_manager
