services:
  docker-in-docker:
    image: docker:dind
    container_name: 'docker_dind'
    privileged: 'true'
    command:
      - 'dockerd'
      - '-H'
      - 'unix:///var/run/docker.sock'
      - '-H'
      - 'tcp://0.0.0.0:2375'
      - '--tls=false'
    healthcheck:
      test: ['CMD', 'docker', 'info']
      interval: '5s'
      timeout: '3s'
      retries: 12
      start_period: '10s'
    restart: 'unless-stopped'

  runner-job-image:
    image: docker:cli
    depends_on:
      docker-in-docker:
        condition: service_healthy
    environment:
      DOCKER_HOST: tcp://docker-in-docker:2375
    volumes:
      - ./job-image:/job-image:ro
    command:
      - 'build'
      - '--network'
      - 'host'
      - '--tag'
      - 'endurain-forgejo-runner-job:node24-docker-cli'
      - '/job-image'

  runner:
    image: 'data.forgejo.org/forgejo/runner:12'
    links:
      - docker-in-docker
    depends_on:
      docker-in-docker:
        condition: service_healthy
      runner-job-image:
        condition: service_completed_successfully
    container_name: 'runner'
    environment:
      DOCKER_HOST: tcp://docker-in-docker:2375
    # User without root privileges, but with access to `./data`.
    user: 1001:1001
    volumes:
      - ./data:/data
    restart: 'unless-stopped'
    command: 'forgejo-runner daemon --config runner-config.yml'