[importlinter]
# Run from backend/ with: PYTHONPATH=app uv run lint-imports
root_packages =
    auth
    users
    activities
    core
    followers
    garmin
    gears
    health
    notifications
    password_reset_tokens
    profile
    server_settings
    sign_up_tokens
    strava
    websocket

[importlinter:contract:auth-boundary]
name = Auth boundary: non-auth must not import auth internals directly
type = forbidden
allow_indirect_imports = True
source_modules =
    users
    activities
    core
    followers
    garmin
    gears
    health
    notifications
    password_reset_tokens
    profile
    server_settings
    sign_up_tokens
    strava
    websocket
forbidden_modules =
    auth.security
    auth.password_hasher
    auth.token_manager
ignore_imports =
    # ---------------------------------------------------------------
    # PR 1 baseline - report-only mode
    # Each subsequent PR removes entries as call sites are migrated
    # to IdentityService. When all entries are removed the contract
    # flips to fully-enforcing mode (Phase 12).
    # ---------------------------------------------------------------

    # auth.security violations
    followers.router -> auth.security
    server_settings.router -> auth.security
    websocket.router -> auth.security
    core.routes -> auth.security
    health.health_water.router -> auth.security
    health.health_fasting.router -> auth.security
    health.health_poop.router -> auth.security
    health.health_sleep.router -> auth.security
    health.health_targets.router -> auth.security
    health.health_steps.router -> auth.security
    health.health_weight.router -> auth.security
    health.router -> auth.security
    strava.bulk_import_utils -> auth.security
    strava.router -> auth.security
    garmin.router -> auth.security
    profile.router -> auth.security
    users.users_goals.router -> auth.security
    users.users_identity_providers.router -> auth.security
    users.users_sessions.router -> auth.security
    users.users_default_gear.router -> auth.security
    users.users.router -> auth.security
    users.users_api_keys.router -> auth.security
    activities.activity_laps.router -> auth.security
    activities.activity_media.router -> auth.security
    activities.activity.router -> auth.security
    activities.activity_workout_steps.router -> auth.security
    activities.activity_streams.router -> auth.security
    activities.activity_summaries.router -> auth.security
    activities.activity_sets.router -> auth.security
    activities.activity_exercise_titles.router -> auth.security
    gears.gear_components.router -> auth.security
    gears.gear_components.dependencies -> auth.security
    gears.gear.router -> auth.security
    notifications.router -> auth.security

    # auth.password_hasher violations
    password_reset_tokens.utils -> auth.password_hasher
    password_reset_tokens.router -> auth.password_hasher
    sign_up_tokens.router -> auth.password_hasher
    profile.utils -> auth.password_hasher
    profile.router -> auth.password_hasher
    users.users_sessions.utils -> auth.password_hasher
    users.users.utils -> auth.password_hasher
    users.users.router -> auth.password_hasher
    users.users_api_keys.router -> auth.password_hasher
    users.users.crud -> auth.password_hasher
