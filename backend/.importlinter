[importlinter]
# Run from backend/ with: PYTHONPATH=app uv run lint-imports
root_packages =
    auth
    users
    activities
    core
    followers
    garmin
    gears
    health
    notifications
    server_settings
    strava
    websocket

[importlinter:contract:auth-boundary]
name = Auth boundary: non-auth must not import auth internals directly
type = forbidden
allow_indirect_imports = True
source_modules =
    users
    activities
    core
    followers
    garmin
    gears
    health
    notifications
    server_settings
    strava
    websocket
forbidden_modules =
    auth.internal_dependencies
    auth.password_hasher
    auth.token_manager

[importlinter:contract:auth-low-level-ownership]
name = Auth boundary: non-auth must not import low-level auth ownership modules directly
type = forbidden
allow_indirect_imports = True
source_modules =
    users
    activities
    core
    followers
    garmin
    gears
    health
    notifications
    server_settings
    strava
    websocket
forbidden_modules =
    auth.password_reset_tokens.crud
    auth.sign_up_tokens.crud
    auth.sessions.crud
    auth.mfa.crud
    auth.mfa.backup_codes.crud
    auth.identity_providers.links.crud
    auth.identity_providers.link_tokens.crud
    auth.credentials.crud
    auth.security_stores
    auth.services
